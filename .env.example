STRIPE_API_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
AUTH_SECRET=change-me-to-32-char-random-string
RESEND_API_KEY=re_...
BROWSERLESS_TOKEN=...
DUTCHIE_API_KEY=...
OVERSEER_CRAWL_URL=https://overseer-crawl.libertydesignstudio.workers.dev
OVERSEER_CRAWL_API_KEY=...
APP_URL=https://dubmenu.com
TV_URL=https://tv.dubmenu.com

# --- DubHaven shared SSO (Google login is delegated to dubhaven.com) ---
# Unauthenticated /config and /account redirect to DubHaven, which performs the
# Google OAuth dance and hands back a signed identity token at
# /auth/dubhaven/callback. These three vars must be set for SSO to work.
#
# DUBHAVEN_AUTH_URL: DubHaven Google OAuth start endpoint. The DubHaven provider
#   must allow this DubMenu origin in its PRODUCT_CALLBACK_ORIGINS allowlist
#   (lib/account/state.ts): https://dubmenu.com, https://www.dubmenu.com,
#   http://localhost:3005.
DUBHAVEN_AUTH_URL=https://dubhaven.com/api/auth/google
# DUBHAVEN_ACCOUNT_SECRET: MUST match the secret on the DubHaven provider
#   (.env.local DUBHAVEN_ACCOUNT_SECRET). Used to verify the identity token.
#   Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
DUBHAVEN_ACCOUNT_SECRET=replace_with_same_64_byte_hex_secret_as_dubhaven_provider
# DUBHAVEN_ISSUER: optional override; defaults to https://dubhaven.com.
# DUBHAVEN_ISSUER=https://dubhaven.com
#
# NOTE on Google OAuth redirect_uri_mismatch:
# Google's redirect_uri is owned by the DubHaven provider, not DubMenu. It is
# built as ${DubHaven request origin}/api/auth/google/callback. For the live
# flow to work, the Google Cloud Console OAuth client used by dubhaven.com MUST
# list these Authorized redirect URIs (see dubhaven-next/.env.example):
#   - https://dubhaven.com/api/auth/google/callback
#   - https://www.dubhaven.com/api/auth/google/callback
#   - http://localhost:3000/api/auth/google/callback
# A redirect_uri_mismatch on the dubhaven.com Google consent screen means one of
# those URIs is missing from the Google Console, not a DubMenu code issue.